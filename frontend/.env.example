# ── Variables de entorno para TechCompare ──
# Copia este archivo como .env y ajusta los valores

# URL del backend (Node/Express)
# En desarrollo local usa localhost:
VITE_API_URL=http://localhost:3001/api

# En producción (Vercel), cambia por tu URL real:
# VITE_API_URL=https://tu-backend.vercel.app/api

# ── Futuro: Catálogo de imágenes en Vercel ──
# Si subes las fotos de productos a Vercel Blob Storage,
# agrega aquí la URL base del bucket para usarla en ProductCard.jsx:
# VITE_IMAGES_URL=https://xxxx.public.blob.vercel-storage.com
#
# Uso en ProductCard.jsx:
#   const IMAGES_URL = import.meta.env.VITE_IMAGES_URL || ''
#   src={producto.image_key ? `${IMAGES_URL}/${producto.image_key}` : null}
